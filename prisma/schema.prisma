generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model article_serials {
  id             Int       @id @default(autoincrement())
  article_id     Int?
  site_id        Int?
  serial_number  String    @unique @db.VarChar(255)
  status         String?   @default("IN_STOCK") @db.VarChar(20)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  purchase_price Decimal?  @db.Decimal(10, 2)
  articles       articles? @relation(fields: [article_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sites          sites?    @relation(fields: [site_id], references: [id], onUpdate: NoAction)
}

model articles {
  id                  Int                   @id @default(autoincrement())
  code_article        String                @unique @db.VarChar(50)
  label               String                @db.VarChar(100)
  description         String?
  ean_code            String?               @unique @db.VarChar(13)
  has_serial_number   Boolean?              @default(false)
  category_id         Int?
  brand_id            Int?
  supplier_id         Int?
  specs               Json?                 @default("{}")
  article_serials     article_serials[]
  inventory_lines     inventory_lines[]
  purchases           purchases[]
  serial_numbers      serial_numbers[]
  site_article_stocks site_article_stocks[]
  stock_history       stock_history[]
}

model brands {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(255)
}

model categories {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(255)
  has_gpu     Boolean? @default(false)
  is_computer Boolean? @default(false)
}

model cpu_brands {
  id         Int          @id @default(autoincrement())
  name       String       @unique @db.VarChar(255)
  cpu_ranges cpu_ranges[]
}

model cpu_models {
  id          Int         @id @default(autoincrement())
  name        String      @db.VarChar(255)
  range_id    Int?
  device_type String?     @db.VarChar(50)
  cpu_ranges  cpu_ranges? @relation(fields: [range_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([name, range_id])
}

model cpu_ranges {
  id         Int          @id @default(autoincrement())
  name       String       @db.VarChar(255)
  brand_id   Int?
  cpu_models cpu_models[]
  cpu_brands cpu_brands?  @relation(fields: [brand_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([name, brand_id])
}

model gpu_brands {
  id         Int          @id @default(autoincrement())
  name       String       @unique @db.VarChar(255)
  gpu_ranges gpu_ranges[]
}

model gpu_models {
  id          Int         @id @default(autoincrement())
  name        String      @db.VarChar(255)
  range_id    Int?
  device_type String?     @db.VarChar(50)
  gpu_ranges  gpu_ranges? @relation(fields: [range_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([name, range_id])
}

model gpu_ranges {
  id         Int          @id @default(autoincrement())
  name       String       @db.VarChar(255)
  brand_id   Int?
  gpu_models gpu_models[]
  gpu_brands gpu_brands?  @relation(fields: [brand_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([name, brand_id])
}

model inventory_campaigns {
  id              Int               @id @default(autoincrement())
  site_id         Int?
  status          String?           @default("IN_PROGRESS") @db.VarChar(50)
  created_at      DateTime?         @default(now()) @db.Timestamp(6)
  completed_at    DateTime?         @db.Timestamp(6)
  sites           sites?            @relation(fields: [site_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  inventory_lines inventory_lines[]
}

model inventory_lines {
  id                  Int                  @id @default(autoincrement())
  campaign_id         Int?
  article_id          Int?
  expected_quantity   Int?                 @default(0)
  counted_quantity    Int?                 @default(0)
  expected_serials    Json?                @default("[]")
  counted_serials     Json?                @default("[]")
  articles            articles?            @relation(fields: [article_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  inventory_campaigns inventory_campaigns? @relation(fields: [campaign_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model os_list {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(255)
}

model purchases {
  id              Int              @id @default(autoincrement())
  article_id      Int?
  purchase_date   DateTime         @default(dbgenerated("CURRENT_DATE")) @db.Date
  unit_price      Decimal          @db.Decimal(10, 2)
  quantity_bought Int
  articles        articles?        @relation(fields: [article_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  serial_numbers  serial_numbers[]
}

model ram_types {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(255)
}

model roles {
  id    Int     @id @default(autoincrement())
  name  String  @unique @db.VarChar(50)
  users users[]
}

model serial_numbers {
  id            Int        @id @default(autoincrement())
  serial_number String     @unique @db.VarChar(100)
  article_id    Int?
  site_id       Int?
  purchase_id   Int?
  articles      articles?  @relation(fields: [article_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  purchases     purchases? @relation(fields: [purchase_id], references: [id], onUpdate: NoAction)
  sites         sites?     @relation(fields: [site_id], references: [id], onUpdate: NoAction)
}

model site_article_stocks {
  site_id         Int
  article_id      Int
  quantity        Int      @default(0)
  alert_threshold Int      @default(0)
  articles        articles @relation(fields: [article_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sites           sites    @relation(fields: [site_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([site_id, article_id])
}

model sites {
  id                                              Int                   @id @default(autoincrement())
  name                                            String                @db.VarChar(100)
  description                                     String?
  is_active                                       Boolean?              @default(true)
  article_serials                                 article_serials[]
  inventory_campaigns                             inventory_campaigns[]
  serial_numbers                                  serial_numbers[]
  site_article_stocks                             site_article_stocks[]
  stock_history_stock_history_from_site_idTosites stock_history[]       @relation("stock_history_from_site_idTosites")
  stock_history_stock_history_to_site_idTosites   stock_history[]       @relation("stock_history_to_site_idTosites")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model stock_history {
  id                                      Int       @id @default(autoincrement())
  article_id                              Int?
  from_site_id                            Int?
  to_site_id                              Int?
  type                                    String?   @db.VarChar(20)
  quantity                                Int
  purchase_price                          Decimal?  @db.Decimal(10, 2)
  purchase_date                           DateTime? @default(dbgenerated("CURRENT_DATE")) @db.Date
  serial_number                           String?   @db.VarChar(255)
  created_at                              DateTime? @default(now()) @db.Timestamp(6)
  sale_price                              Decimal?  @db.Decimal(10, 2)
  articles                                articles? @relation(fields: [article_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sites_stock_history_from_site_idTosites sites?    @relation("stock_history_from_site_idTosites", fields: [from_site_id], references: [id], onUpdate: NoAction)
  sites_stock_history_to_site_idTosites   sites?    @relation("stock_history_to_site_idTosites", fields: [to_site_id], references: [id], onUpdate: NoAction)
}

model storage_types {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(255)
}

model suppliers {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(255)
}

model users {
  id            Int    @id @default(autoincrement())
  username      String @unique @db.VarChar(100)
  password_hash String @db.VarChar(255)
  role_id       Int?
  roles         roles? @relation(fields: [role_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
}
